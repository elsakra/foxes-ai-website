{
  "rewrites": [
    { "source": "/build", "destination": "/build.html" },
    { "source": "/onboarding", "destination": "/onboarding.html" },
    { "source": "/lander", "destination": "/lander.html" },
    { "source": "/diy", "destination": "/diy.html" },
    { "source": "/funnel", "destination": "/funnel.html" }
  ],
  "redirects": [
    { "source": "/home.html", "destination": "/", "permanent": true },
    {
      "source": "/admin",
      "destination": "https://foxes-ai-platform.vercel.app/admin",
      "permanent": false
    },
    {
      "source": "/admin/:path*",
      "destination": "https://foxes-ai-platform.vercel.app/admin/:path*",
      "permanent": false
    }
  ]
}
