# Supabase (Next.js server + public URL)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# App URL (used in emails, Meta CAPI, redirects)
NEXT_PUBLIC_APP_ORIGIN=https://your-deployment.vercel.app

# Extra browser origins allowed to POST /api/leads from a static onboarding bundle (CORS), merged at runtime with
# https://foxes.ai, https://www.foxes.ai, and common localhost origins—set this only if you need preview URLs or staging.
# FUNNEL_ALLOWED_ORIGINS is a legacy alias (same comma list).
ONBOARDING_ALLOWED_ORIGINS=
FUNNEL_ALLOWED_ORIGINS=

# Admin JWT (set long random strings in production)
ADMIN_PASSWORD=
ADMIN_JWT_SECRET=

# Email (Resend)
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@yourdomain.com

# SMS (Twilio)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Slack incoming webhook for new leads
SLACK_WEBHOOK_URL=

# Meta Conversions API
META_PIXEL_ID=
META_CAPI_ACCESS_TOKEN=
META_TEST_EVENT_CODE=

# Stripe ($197/mo subscription — create Price in Dashboard)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Anthropic (generate draft in admin)
ANTHROPIC_API_KEY=

# Public embeds for onboarding (Vimeo / YouTube iframe src)
NEXT_PUBLIC_VSL_EMBED_URL=
NEXT_PUBLIC_CONFIRMATION_VIDEO_EMBED_URL=

# Meta Pixel (browser)
NEXT_PUBLIC_META_PIXEL_ID=
