# Vite static site — points the onboarding bundle at your Next.js API (same hostname or separate Vercel URL).
# Copy to `.env.local` for local dev: `cp .env.example .env.local`

# Base URL of the Next.js app serving /api/leads (no trailing slash).
VITE_ONBOARDING_API_ORIGIN=https://your-next-app.vercel.app

# Legacy: full URL including /api/leads — resolved to origin for API calls if present and VITE_ONBOARDING_API_ORIGIN is unset
VITE_FUNNEL_API_URL=https://your-next-app.vercel.app/api/leads

# CORS /api/leads from static foxes.ai: defaults include https://foxes.ai (+ www); add previews here if needed.

# Optional: Vimeo / YouTube iframe embed URLs
VITE_ONBOARDING_VSL_EMBED_URL=
VITE_ONBOARDING_CONFIRM_EMBED_URL=
VITE_FUNNEL_VSL_EMBED_URL=
VITE_FUNNEL_CONFIRMATION_EMBED_URL=

# Optional: Meta Pixel (browser)
VITE_ONBOARDING_META_PIXEL_ID=
VITE_FUNNEL_META_PIXEL_ID=
