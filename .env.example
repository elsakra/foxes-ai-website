# Vite static site — points the funnel form at the Next.js API (same deployment or Vercel URL).
# Copy to `.env.local` for local dev: `cp .env.example .env.local`

# Full URL to POST JSON (must match `FUNNEL_ALLOWED_ORIGINS` on the Next app if cross-origin).
VITE_FUNNEL_API_URL=https://your-next-app.vercel.app/api/leads

# Optional: Vimeo / YouTube iframe embed URLs
VITE_FUNNEL_VSL_EMBED_URL=
VITE_FUNNEL_CONFIRMATION_EMBED_URL=

# Optional: Meta Pixel (browser)
VITE_FUNNEL_META_PIXEL_ID=
