# Vite static site — points the onboarding bundle at your Next.js API (same hostname or separate Vercel URL).
# Copy to `.env.local` for local dev: `cp .env.example .env.local`

# Optional: override Next.js origin for /api/leads. If unset, production bundles use foxes-ai-platform.vercel.app; local file/open from localhost uses http://localhost:3000.
VITE_ONBOARDING_API_ORIGIN=

# Legacy: full URL including /api/leads — resolved to origin for API calls if present and VITE_ONBOARDING_API_ORIGIN is unset
VITE_FUNNEL_API_URL=https://your-next-app.vercel.app/api/leads

# CORS /api/leads from static foxes.ai: defaults include https://foxes.ai (+ www); add previews here if needed.

# Optional: Vimeo / YouTube iframe embed URLs
VITE_ONBOARDING_VSL_EMBED_URL=
VITE_ONBOARDING_CONFIRM_EMBED_URL=
VITE_FUNNEL_VSL_EMBED_URL=
VITE_FUNNEL_CONFIRMATION_EMBED_URL=

# Optional: Meta Pixel (browser)
VITE_ONBOARDING_META_PIXEL_ID=
VITE_FUNNEL_META_PIXEL_ID=

# Preview-request experiment (/preview): email-first native form redirects to this Typeform.
# Public Typeform form ID only, never a personal token.
# Build the Typeform with hidden fields:
# preview_lead_id, event_id, utm_source, utm_medium, utm_campaign, utm_content, utm_term, fbclid, gclid, source_page, page_url, page_path, referrer
VITE_PREVIEW_TYPEFORM_ID=
VITE_PREVIEW_TYPEFORM_URL=
VITE_PREVIEW_API_ORIGIN=

# Optional local helper to create the Typeform and connect a Make.com custom webhook.
# Do not place real values in committed files:
# TYPEFORM_PERSONAL_TOKEN=... MAKE_WEBHOOK_URL=... npm run create:preview-typeform
